# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Supabase (PostgreSQL persistence) ───────────────────────
# Get from: https://supabase.com/dashboard → project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Pinecone (Vector DB for RAG) ────────────────────────────
# Get from: https://app.pinecone.io → API Keys
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX=yatra-policy
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ─── Auth ────────────────────────────────────────────────────
# Comma-separated list of valid API keys for X-API-Key header
API_KEYS=your-secure-key-here,another-key-if-needed

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.hf.space
